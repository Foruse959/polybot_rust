# Polymarket Bot (Rust) — Environment Configuration
# Copy this to .env and fill in your values

# Trading mode: "live" or "paper"
TRADING_MODE=paper

# Wallet (required for live mode)
POLY_PRIVATE_KEY=0x_your_private_key_here
POLY_PROXY_WALLET=0x_your_proxy_wallet_here

# Signature type: 3 for new V2 accounts (browser wallet)
POLY_SIGNATURE_TYPE=3

# API credentials (from polymarket.com → Settings → API)
POLY_API_KEY=
POLY_API_SECRET=
POLY_PASSPHRASE=

# Coins and timeframes
ENABLED_COINS=BTC
ENABLED_TIMEFRAMES=5

# Starting balance (will be overridden by on-chain balance in live mode)
STARTING_BALANCE=5.0
